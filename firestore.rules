rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isVisibilityAllowed(visibility) {
      return visibility in ['public', 'unlisted'];
    }

    function hasValidRoomShape(data) {
      return data.keys().hasAll([
          'roomId',
          'name',
          'description',
          'visibility',
          'ownerId',
          'shareLinkHash',
          'shareSalt',
          'members',
          'createdAt',
          'updatedAt',
        ]) &&
        data.keys().hasOnly([
          'roomId',
          'name',
          'description',
          'visibility',
          'ownerId',
          'shareLinkHash',
          'shareSalt',
          'members',
          'createdAt',
          'updatedAt',
        ]);
    }

    function hasValidOwnerMember(members, ownerId) {
      return members is map &&
        members.keys().hasAll([ownerId]) &&
        members[ownerId] is map &&
        members[ownerId].keys().hasAll(['userId', 'role', 'joinedAt']) &&
        members[ownerId].keys().hasOnly(['userId', 'role', 'joinedAt']) &&
        members[ownerId].userId == ownerId &&
        members[ownerId].role == 'owner' &&
        members[ownerId].joinedAt is timestamp;
    }

    function hasValidRoomValues(data, roomId) {
      return data.roomId == roomId &&
        isNonEmptyString(data.name) &&
        data.description is string &&
        isVisibilityAllowed(data.visibility) &&
        isNonEmptyString(data.ownerId) &&
        isNonEmptyString(data.shareLinkHash) &&
        isNonEmptyString(data.shareSalt) &&
        hasValidOwnerMember(data.members, data.ownerId);
    }

    function hasValidMembershipShape(data) {
      return data.keys().hasAll([
          'roomId',
          'userId',
          'role',
          'createdAt',
          'updatedAt',
        ]) &&
        data.keys().hasOnly([
          'roomId',
          'userId',
          'role',
          'createdAt',
          'updatedAt',
        ]);
    }

    function hasValidMembershipValues(data, userId, roomId) {
      return data.roomId == roomId &&
        data.userId == userId &&
        data.role == 'owner';
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    match /rooms/{roomId} {
      allow create: if isOwner(request.resource.data) &&
        hasValidRoomShape(request.resource.data) &&
        hasValidRoomValues(request.resource.data, roomId);

      allow read: if resource.data.visibility == 'public' ||
        isOwner(resource.data);

      allow update: if isOwner(resource.data) &&
        hasValidRoomShape(request.resource.data) &&
        hasValidRoomValues(request.resource.data, roomId) &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.roomId == resource.data.roomId &&
        request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isOwner(resource.data);
    }

    match /users/{userId}/memberships/{roomId} {
      allow read: if isSignedIn() && request.auth.uid == userId;

      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        hasValidMembershipShape(request.resource.data) &&
        hasValidMembershipValues(request.resource.data, userId, roomId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
